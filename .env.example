# MongoDB connection string (MongoDB Atlas - cloud)
# Get this from https://cloud.mongodb.com → Connect → Drivers
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/college-event-id-verification?retryWrites=true&w=majority

# Session secret for express-session
SESSION_SECRET=your_session_secret_here

# Server port (optional)
PORT=3000
