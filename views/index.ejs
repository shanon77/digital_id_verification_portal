<%- include('partials/header') %>

    <section class="hero">
        <div class="hero-content">
            <h1>🎓 Digital Event ID Verification Portal</h1>
            <p>Register for college events and get instantly verified!</p>
            <div class="hero-buttons">
                <a href="/events" class="btn btn-primary btn-lg">📅 View All Events</a>
            </div>
        </div>
    </section>

    <section class="features-section">
        <h2>Why Use Our Portal?</h2>
        <div class="features-grid">
            <div class="feature-card">
                <div class="feature-icon">⚡</div>
                <h3>Instant Verification</h3>
                <p>Get your ID verified instantly upon registration. No waiting, no hassles!</p>
            </div>
            <div class="feature-card">
                <div class="feature-icon">📱</div>
                <h3>Easy Registration</h3>
                <p>Simple and quick registration process for all college events.</p>
            </div>
            <div class="feature-card">
                <div class="feature-icon">📊</div>
                <h3>Track Status</h3>
                <p>Check your verification status anytime, anywhere.</p>
            </div>
            <div class="feature-card">
                <div class="feature-icon">🔒</div>
                <h3>Secure & Safe</h3>
                <p>Your data is protected with industry-standard security measures.</p>
            </div>
        </div>
    </section>

    <section class="cta-section">
        <h2>Ready to Get Started?</h2>
        <p>Browse through all available events and register for the ones you're interested in.</p>
        <a href="/events" class="btn btn-primary btn-lg">Explore Events →</a>
    </section>

    <style>
        .hero {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 80px 20px;
            text-align: center;
            margin-bottom: 60px;
            border-radius: 10px;
        }

        .hero-content h1 {
            font-size: 3em;
            margin-bottom: 15px;
            font-weight: 700;
        }

        .hero-content > p {
            font-size: 1.3em;
            margin-bottom: 40px;
            opacity: 0.95;
        }

        .hero-buttons {
            display: flex;
            gap: 20px;
            justify-content: center;
            flex-wrap: wrap;
        }

        .btn-lg {
            padding: 15px 40px;
            font-size: 18px;
            border-radius: 6px;
            text-decoration: none;
            display: inline-block;
            font-weight: 600;
            transition: all 0.3s ease;
        }

        .btn-primary {
            background-color: #28a745;
            color: white;
        }

        .btn-primary:hover {
            background-color: #218838;
            transform: translateY(-3px);
            box-shadow: 0 10px 20px rgba(0, 0, 0, 0.2);
        }

        .btn-secondary {
            background-color: rgba(255, 255, 255, 0.3);
            color: white;
            border: 2px solid white;
        }

        .btn-secondary:hover {
            background-color: rgba(255, 255, 255, 0.2);
            transform: translateY(-3px);
        }

        .features-section {
            margin: 60px 0;
        }

        .features-section h2 {
            text-align: center;
            font-size: 2.5em;
            margin-bottom: 50px;
            color: #333;
        }

        .features-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 30px;
            margin-bottom: 60px;
        }

        .feature-card {
            background: white;
            padding: 40px 30px;
            border-radius: 8px;
            text-align: center;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
            transition: all 0.3s ease;
        }

        .feature-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.15);
        }

        .feature-icon {
            font-size: 3em;
            margin-bottom: 15px;
        }

        .feature-card h3 {
            font-size: 1.3em;
            margin-bottom: 15px;
            color: #333;
        }

        .feature-card p {
            color: #666;
            line-height: 1.6;
        }

        .cta-section {
            background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
            color: white;
            padding: 80px 40px;
            text-align: center;
            border-radius: 10px;
            margin: 60px 0;
        }

        .cta-section h2 {
            font-size: 2.5em;
            margin-bottom: 15px;
            font-weight: 700;
        }

        .cta-section > p {
            font-size: 1.1em;
            margin-bottom: 40px;
            opacity: 0.95;
        }

        @media (max-width: 768px) {
            .hero {
                padding: 50px 20px;
            }

            .hero-content h1 {
                font-size: 2em;
            }

            .hero-content > p {
                font-size: 1em;
            }

            .hero-buttons {
                flex-direction: column;
            }

            .btn-lg {
                width: 100%;
                padding: 12px 20px;
                font-size: 16px;
            }

            .features-section h2 {
                font-size: 1.8em;
            }

            .cta-section h2 {
                font-size: 1.8em;
            }

            .cta-section {
                padding: 50px 20px;
            }
        }
    </style>

    <%- include('partials/footer') %>
